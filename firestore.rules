rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: là coach nếu email khớp HOẶC role == 'coach' trong Firestore
    function isCoach() {
      return request.auth != null && (
        request.auth.token.email == 'chuhailong1810199@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach')
      );
    }

    // ── Helper: user hiện tại là chủ của clientId (email khớp)
    function isClientOwner(clientId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/clients/$(clientId)) &&
        get(/databases/$(database)/documents/clients/$(clientId)).data.email == request.auth.token.email;
    }

    // ── LEADS collection ─────────────────────────────────
    // Public: ai cũng có thể tạo lead (contact form từ landing page)
    // Coach only: đọc, update, xóa
    match /leads/{leadId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'email']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 0 &&
        request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'goal', 'frequency',
          'service', 'note', 'createdAt', 'source', 'status'
        ]);

      allow read, update, delete: if isCoach();
    }

    // ── USERS collection ─────────────────────────────────
    // Mỗi user chỉ đọc/ghi profile của chính mình
    // Coach có thể đọc tất cả (để kiểm tra role)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isCoach();
    }

    // ── EXERCISES collection (thư viện bài tập) ──────────
    // Tất cả user đã login đều được đọc
    // Chỉ coach mới được thêm/sửa/xóa
    match /exercises/{docId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    // ── CLIENTS collection ────────────────────────────────
    // Coach: full access tất cả clients
    // Client: chỉ đọc/ghi data của chính mình (khớp email)
    match /clients/{clientId} {
      allow read, write: if isCoach() || isClientOwner(clientId);

      // Tất cả subcollections ở MỌI độ sâu:
      // assessment, checkpoints, workoutHistory, workoutHistory/{id}/exercises,
      // videos, progressPhotos, sessionLoads
      match /{document=**} {
        allow read, write: if isCoach() || isClientOwner(clientId);
      }
    }
  }
}
